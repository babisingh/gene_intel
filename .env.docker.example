# ── Gene-Intel — Docker Compose environment template ─────────────────────────
#
# Copy to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# IMPORTANT: .env.docker is in .gitignore — never commit real credentials.
#
# Usage:
#   docker compose --env-file .env.docker up -d
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#       --env-file .env.docker up -d

# ── Neo4j (Docker internal — NOT neo4j+s:// Aura) ────────────────────────────
# The app container connects via Docker DNS (bolt://neo4j:7687).
# Local ingest scripts connect via bolt://localhost:7687 (port exposed to host).
NEO4J_PASSWORD=change_me_strong_password_here

# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
AGENT_LLM_MODEL=claude-sonnet-4-6
AGENT_LLM_MAX_TOKENS=2048

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# Comma-separated allowed CORS origins.
# Add your public domain here for production.
# e.g. CORS_ORIGINS=https://geneintel.yourdomain.com
CORS_ORIGINS=http://localhost:8000

# ── Local ingest (run on host, NOT inside container) ─────────────────────────
# When running ingestion scripts from your laptop against the Docker Neo4j,
# set these in your shell (or a separate .env_ingest file):
#
#   export NEO4J_URI=bolt://localhost:7687
#   export NEO4J_USER=neo4j
#   export NEO4J_PASSWORD=<same as above>
#   cd backend
#   python -m app.ingestion.run_ingest --all --domain-source ftp \
#       --ftp-file data/interpro_ftp/protein2ipr.dat.gz
