# ── Tinsel environment variables ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Application
TINSEL_ENV=development          # development | staging | production
LOG_LEVEL=info                  # debug | info | warning | error

# API
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
TINSEL_API_URL=http://localhost:8000

# Gate adapter secrets (leave blank to use mock adapters)
ESMFOLD_API_KEY=
NCBI_API_KEY=
TOXINPRED_API_KEY=

# Observability (optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
