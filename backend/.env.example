# ── Neo4j Aura (cloud) ─────────────────────────────────────────────────────────
# Connect to Neo4j Aura — NOT a local Neo4j instance.
# The same URI is used for both local ingestion and the Railway web service.
NEO4J_URI=neo4j+s://<your-aura-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-aura-password>

# ── AI / LLM ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
AGENT_LLM_MODEL=claude-sonnet-4-6
AGENT_LLM_MAX_TOKENS=2048

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production

# ── Local data paths (ingestion only — NOT used by the Railway web service) ────
# GTF and BioMart files live on your local machine (or ingestion CI runner).
# They are excluded from the Docker image via .dockerignore.
# After ingestion these env vars are not needed in Railway — all data is in Aura.
GTF_DATA_DIR=../data/gtf
BIOMART_DATA_DIR=../data/biomart

# ── Architecture summary ───────────────────────────────────────────────────────
# Local workflow:
#   1. bash scripts/download_ensembl.sh          # download GTF files (~10 GB total)
#   2. python scripts/download_biomart.py        # download domain TSVs (~100 MB)
#   3. python -m app.ingestion.run_ingest --all  # ingest into Neo4j Aura
#
# Railway workflow (no data files needed):
#   - Set NEO4J_URI / NEO4J_PASSWORD / ANTHROPIC_API_KEY in Railway Variables
#   - Push to main → Railway builds Dockerfile and deploys
#   - The app reads from Aura; no GTF/BioMart data ever enters the container
